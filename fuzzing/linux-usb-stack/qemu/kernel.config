# Linux USB stack fuzzing VM — minimal kernel configuration fragment.
#
# Applied over `make allnoconfig` using:
#   scripts/kconfig/merge_config.sh -m .config ../qemu/kernel.config
#   make olddefconfig
#
# Targets: USB core/enumeration, USB gadget framework, host controller drivers.
# Instrument with KASAN + UBSAN + KCOV for maximum crash visibility.
# syzkaller uses KCOV for coverage feedback and KASAN to detect memory errors.

# ── basic 64-bit SMP kernel ──────────────────────────────────────────────
CONFIG_64BIT=y
CONFIG_SMP=y
CONFIG_NR_CPUS=4
CONFIG_PREEMPT_NONE=y
CONFIG_HZ_100=y

# ── needed for kernel to function correctly ──────────────────────────────
CONFIG_PRINTK=y
CONFIG_BUG=y
CONFIG_ELF_CORE=n
CONFIG_FUTEX=y
CONFIG_EPOLL=y
CONFIG_SIGNALFD=y
CONFIG_EVENTFD=y
CONFIG_AIO=y
CONFIG_ADVISE_SYSCALLS=y
CONFIG_MEMFD_CREATE=y
CONFIG_POSIX_TIMERS=y

# ── memory ───────────────────────────────────────────────────────────────
CONFIG_MEMORY_ISOLATION=n
CONFIG_SLUB=y
# KASAN requires slab merging disabled — merged slabs collapse redzone separation
CONFIG_SLAB_MERGE_DEFAULT=n

# ── networking ───────────────────────────────────────────────────────────
CONFIG_NET=y
CONFIG_INET=y
CONFIG_PACKET=y
CONFIG_UNIX=y
CONFIG_IPV6=n
CONFIG_TCP_CONG_CUBIC=y
CONFIG_DEFAULT_TCP_CONG="cubic"
CONFIG_NETFILTER=n
CONFIG_NET_SCHED=n

# ── network device drivers ───────────────────────────────────────────────
CONFIG_NETDEVICES=y
CONFIG_ETHERNET=y
CONFIG_NET_VENDOR_INTEL=y
CONFIG_E1000=y
CONFIG_VIRTIO_NET=y

# ── PCI (needed for e1000 and USB host controllers) ──────────────────────
CONFIG_PCI=y
CONFIG_PCIEPORTBUS=y

# ── USB core ─────────────────────────────────────────────────────────────
CONFIG_USB_SUPPORT=y
CONFIG_USB=y
CONFIG_USB_PCI=y
CONFIG_USB_HCD_TEST_MODE=n
CONFIG_USB_ANNOUNCE_NEW_DEVICES=y

# ── USB host controllers (xHCI + EHCI exercised by dummy_hcd enumeration) ─
CONFIG_USB_XHCI_HCD=y
CONFIG_USB_XHCI_PCI=y
CONFIG_USB_EHCI_HCD=y
CONFIG_USB_EHCI_PCI=y
CONFIG_USB_OHCI_HCD=y
CONFIG_USB_OHCI_HCD_PCI=y

# ── raw_gadget + dummy_hcd — the core of syz_usb_connect fuzzing ─────────
#
# dummy_hcd acts as both a USB host controller and a USB device controller
# simultaneously. raw_gadget exposes the device side to userspace, so
# syzkaller can present arbitrary USB descriptors to the kernel's USB core.
#
# Attack flow: syzkaller writes crafted descriptors via raw_gadget →
#   USB core parses them (CONFIG_USB) → host controller driver handles URBs
#   (CONFIG_USB_XHCI_HCD etc.) → class drivers bind (HID, storage, etc.)
CONFIG_USB_GADGET=y
CONFIG_USB_DUMMY_HCD=y
CONFIG_USB_RAW_GADGET=y

# ── USB gadget framework (configfs interface) ────────────────────────────
# Exercised by syzkaller-gadget-fw profile: mkdir/write on configfs paths.
CONFIG_CONFIGFS_FS=y
CONFIG_USB_CONFIGFS=y
CONFIG_USB_CONFIGFS_SERIAL=y
CONFIG_USB_CONFIGFS_ACM=y
CONFIG_USB_CONFIGFS_NCM=y
CONFIG_USB_CONFIGFS_MASS_STORAGE=y
CONFIG_USB_CONFIGFS_F_HID=y
CONFIG_USB_CONFIGFS_F_UVC=y

# ── USB class drivers (bind when fake device enumerates via dummy_hcd) ───
CONFIG_USB_HID=y
CONFIG_HID=y
CONFIG_HID_GENERIC=y
CONFIG_USB_HIDDEV=y
CONFIG_USB_STORAGE=y
CONFIG_USB_ACM=y
CONFIG_USB_SERIAL=y
CONFIG_USB_SERIAL_GENERIC=y

# ── modules ──────────────────────────────────────────────────────────────
CONFIG_MODULES=y
CONFIG_MODULE_UNLOAD=y
CONFIG_MODULE_FORCE_UNLOAD=n

# ── filesystem / initramfs ───────────────────────────────────────────────
CONFIG_TMPFS=y
CONFIG_PROC_FS=y
CONFIG_PROC_SYSCTL=y
CONFIG_SYSFS=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
CONFIG_BLK_DEV_INITRD=y
CONFIG_RD_GZIP=y
CONFIG_INITRAMFS_SOURCE=""

# ── TTY / serial console ─────────────────────────────────────────────────
CONFIG_TTY=y
CONFIG_VT=n
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
CONFIG_SERIAL_8250_NR_UARTS=4

# ── clock / timers ───────────────────────────────────────────────────────
CONFIG_RTC_CLASS=y
CONFIG_HW_RANDOM=y

# ── namespaces (syzkaller sandbox support) ───────────────────────────────
CONFIG_NAMESPACES=y
CONFIG_UTS_NS=y
CONFIG_IPC_NS=y
CONFIG_PID_NS=y
CONFIG_NET_NS=y
CONFIG_USER_NS=y
CONFIG_CGROUPS=y

# ── disable as much as possible for fast boot ────────────────────────────
CONFIG_ACPI=n
CONFIG_ACPI_SLEEP=n
CONFIG_HIBERNATION=n
CONFIG_SUSPEND=n
CONFIG_PM=n
CONFIG_SOUND=n
CONFIG_DRM=n
CONFIG_FB=n
CONFIG_FRAMEBUFFER_CONSOLE=n
CONFIG_INPUT=n
CONFIG_SERIO=n
CONFIG_WIRELESS=n
CONFIG_RFKILL=n
CONFIG_CRYPTO_HW=n

# ── sanitizers (KASAN, KCOV, UBSAN) ─────────────────────────────────────
# KASAN: catches heap overflows, UAF, OOB reads.
# Overhead: ~2x slowdown, 8x extra RAM. Use -m 2048M in QEMU.
CONFIG_KASAN=y
CONFIG_KASAN_GENERIC=y
CONFIG_KASAN_OUTLINE=y
CONFIG_KASAN_TAGS=n

# UBSAN: catches undefined behaviour (integer overflow, OOB, etc.)
CONFIG_UBSAN=y
CONFIG_UBSAN_BOUNDS=y
CONFIG_UBSAN_SANITIZE_ALL=y

CONFIG_DEBUG_LIST=y

# KCOV: syzkaller's coverage feedback mechanism.
# syzkaller reads /sys/kernel/debug/kcov per-task to guide mutation.
CONFIG_KCOV=y
CONFIG_KCOV_ENABLE_COMPARISONS=y
CONFIG_KCOV_INSTRUMENT_ALL=y

CONFIG_DEBUG_FS=y
CONFIG_PANIC_ON_OOPS=y

CONFIG_CC_OPTIMIZE_FOR_SIZE=n
CONFIG_KERNEL_XZ=n
CONFIG_KERNEL_GZIP=y
